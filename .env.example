# Copy to .env and adjust (the app reads real environment variables; .env is loaded by run.sh).
HOST=127.0.0.1
PORT=8000

# Optional API key. If set, the client must send "Authorization: Bearer <key>".
# Leave empty = no auth (local only!).
API_KEY=

# Path/name of the Claude CLI binary.
CLAUDE_BIN=claude

# Default model when the client sends none/an unknown one: sonnet | opus | haiku | default
DEFAULT_MODEL=sonnet

# Timeout per request in seconds.
REQUEST_TIMEOUT=180

# --- Perf knobs (empty = CLI default) ---
# Effort lowers compute/thinking (CLI default is "high"): low | medium | high | xhigh | max
# This is only the DEFAULT — clients may override per request via OpenAI `reasoning_effort`
# or OpenRouter `reasoning.effort`. Note: per-request effort is part of the pool bucket key.
EFFORT=
# Replaces the large (~6.5k token) CLI system prompt with your own small one.
# Note: tool-use instructions are gone then -> verify tool reliability.
SYSTEM_PROMPT=
# Alternatively from a file (only if SYSTEM_PROMPT is empty):
SYSTEM_PROMPT_FILE=

# --- Process pool (reuse) — saves spawn/init overhead per request ---
POOL_ENABLED=1
POOL_MAX_PROCS=8
POOL_IDLE_TTL=180        # seconds idle before an instance is reaped
POOL_MAX_USES=100        # recycle an instance after this many turns
POOL_REAP_INTERVAL=30
CLEAR_TIMEOUT=15         # /clear is instant; keep this short

# Metrics window (number of recent requests kept for latency percentiles).
METRICS_WINDOW=1000

# Debug/Logging
DEBUG=0
LOG_CLI_STDERR=0
